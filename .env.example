# Database
# SQLite (default for local dev — no setup needed):
DATABASE_URL=sqlite:///./cti.db

# PostgreSQL (switch when ready):
# DATABASE_URL=postgresql+psycopg2://cti_user:changeme@localhost:5432/cti_platform

# LLM (Ollama local — make sure `ollama serve` is running)
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b

# Anthropic (optional fallback — leave blank if using Ollama)
ANTHROPIC_API_KEY=

# Semantic embeddings (optional but recommended — enables semantic chat
# retrieval and similarity-based feedback signals):
#   ollama pull nomic-embed-text
# EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_MODEL=

# External data (all optional — platform works without them)
NVD_API_KEY=

# Enrichment pipeline
ENRICH_DELAY_SECONDS=0

# Bulletin
BULLETIN_MAX_ITEMS=30

# Optional: push the daily brief to an ntfy-style webhook after the scheduled
# bulletin build (plain-text POST). e.g. https://ntfy.sh/your-topic
BRIEF_WEBHOOK_URL=

# Scheduled jobs (UTC hours)
INGEST_HOUR=7
ENRICH_HOUR=8
CVE_SYNC_HOUR=9
BULLETIN_HOUR=10
# Set false for tests or when an external scheduler owns pipeline execution
SCHEDULER_ENABLED=true

# Auth
SECRET_KEY=change-me-use-a-long-random-string
AUTH_USERNAME=admin
AUTH_PASSWORD=wraith

# API
LOG_LEVEL=INFO
